{
	"name": "shadow-accept",
	"displayName": "Shadow Accept",
	"description": "Auto-accept AI agent prompts in VS Code, Antigravity and Cursor. Zero-config terminal monitor + CDP fallback. 100% free, no limits, open source by NakedoMedia.",
	"version": "1.2.0",
	"publisher": "NakedoMedia",
	"license": "MIT",
	"icon": "media/icon.png",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/NakedoMedia/shadow-accept.git"
	},
	"categories": [
		"Machine Learning",
		"Programming Languages",
		"Other"
	],
	"keywords": [
		"antigravity",
		"cursor",
		"windsurf",
		"vscode",
		"ai",
		"auto-accept",
		"agent",
		"copilot",
		"claude",
		"claude-code",
		"aider",
		"cody",
		"terminal",
		"zero-config",
		"productivity",
		"automation",
		"developer-tools",
		"open-source"
	],
	"engines": {
		"vscode": "^1.83.0"
	},
	"enabledApiProposals": [
		"terminalDataWriteEvent"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "dist/extension.js",
	"scripts": {
		"compile": "npx esbuild extension.js --bundle --outfile=dist/extension.js --external:vscode --platform=node --format=cjs",
		"package": "npx vsce package",
		"test": "node test/test.js"
	},
	"contributes": {
		"commands": [
			{
				"command": "shadow-accept.toggle",
				"title": "Shadow Accept: Toggle ON/OFF"
			},
			{
				"command": "shadow-accept.openSettings",
				"title": "Shadow Accept: Settings"
			},
			{
				"command": "shadow-accept.quickAccept",
				"title": "Shadow Accept: Quick Accept (send Y to terminal)"
			}
		],
		"keybindings": [
			{
				"command": "shadow-accept.quickAccept",
				"key": "ctrl+shift+y",
				"mac": "cmd+shift+y",
				"when": "terminalFocus"
			}
		],
		"configuration": {
			"title": "Shadow Accept",
			"properties": {
				"shadowAccept.pollInterval": {
					"type": "number",
					"default": 800,
					"minimum": 300,
					"maximum": 5000,
					"description": "Polling interval in milliseconds (how often to scan for accept buttons via CDP engine)"
				},
				"shadowAccept.bannedCommands": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [
						"rm -rf /",
						"rm -rf ~",
						"rm -rf *",
						"format c:",
						"del /f /s /q",
						"rmdir /s /q",
						":(){:|:&};:",
						"dd if=",
						"mkfs.",
						"> /dev/sda",
						"chmod -R 777 /"
					],
					"description": "Command patterns that will never be auto-accepted. Supports plain substrings or /regex/flags."
				},
				"shadowAccept.enableOnStartup": {
					"type": "boolean",
					"default": false,
					"description": "Automatically enable Shadow Accept when VS Code starts"
				},
				"shadowAccept.debugPort": {
					"type": "number",
					"default": 0,
					"minimum": 0,
					"maximum": 65535,
					"description": "Custom CDP debug port (0 = auto-scan common ports like 9222, 9229, 9000-9006)"
				},
				"shadowAccept.engineMode": {
					"type": "string",
					"default": "auto",
					"enum": [
						"auto",
						"terminal-only",
						"cdp-only"
					],
					"enumDescriptions": [
						"Try terminal monitor first (zero-config), use CDP as fallback",
						"Terminal monitor only, skip CDP engine",
						"CDP only (v1.1 behavior, requires --remote-debugging-port)"
					],
					"description": "Engine mode: auto (recommended), terminal-only, or cdp-only"
				},
				"shadowAccept.terminalPatterns": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "Additional regex patterns to match in terminal output. Each pattern triggers an auto-accept (Y) response."
				}
			}
		}
	},
	"devDependencies": {
		"esbuild": "^0.27.3"
	},
	"dependencies": {
		"ws": "^8.19.0"
	},
	"author": "NakedoMedia (https://nakedo.ai)",
	"type": "commonjs",
	"bugs": {
		"url": "https://github.com/NakedoMedia/shadow-accept/issues"
	},
	"homepage": "https://nakedo.ai"
}
